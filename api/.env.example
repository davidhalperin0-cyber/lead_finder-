# שרת בלבד — ללא קידומת NEXT_PUBLIC_ (ה-API קורא שמות אלה בדיוק)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# מ-Settings → API → JWT Secret (לא ה-anon key)
SUPABASE_JWT_SECRET=your-jwt-secret

# אל תשימי service_role או JWT secret ב-web/.env.local — אף פעם לא ב-NEXT_PUBLIC_

# אופציונלי — מקורות מותרים ל-CORS (פסיקים)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ניתוח AI ב-pipeline (אותו .env כמו בשורש או כאן)
OPENAI_API_KEY=

# Supabase Storage bucket name (create it in Storage UI)
SUPABASE_SCREENSHOTS_BUCKET=screenshots
